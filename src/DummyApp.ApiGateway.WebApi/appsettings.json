{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "StorageService": {
    "BaseUrl": "http://storage.dummy.localhost",
    "IgnoreSslErrors": true
  },
  "Identity": {
    "Authority": "http://identity.dummy.localhost",
    "MetadataAddress": "http://identity:8080/.well-known/openid-configuration",
    "ClientId": "storage-client",
    "ClientSecret": "storage-secret"
  },
  "IdentityJwt": {
    "Authority": "http://identity.dummy.localhost",
    "MetadataAddress": "http://identity:8080/.well-known/openid-configuration"
  }
}
